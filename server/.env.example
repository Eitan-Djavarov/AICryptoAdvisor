# Server
PORT=5000
NODE_ENV=development

# SQLite (Prisma)
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# OpenRouter (AI)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini

# Crypto market data (e.g. CoinGecko — no key required for free tier)
COINGECKO_API_BASE=https://api.coingecko.com/api/v3

# CryptoPanic (news — optional; fallback data used if missing or rate-limited)
CRYPTOPANIC_API_KEY=your-cryptopanic-api-key

# CORS
CLIENT_URL=http://localhost:5173

# Public API base URL (used for meme image proxy links returned to the client)
API_PUBLIC_BASE_URL=http://localhost:5000
