# Server
PORT=5000
NODE_ENV=development

# PostgreSQL (Prisma) — provider must remain "postgresql"
# Local development (Neon dev branch or local Postgres):
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require"
#
# Production (Neon pooled connection — set in your host env, e.g. Render/Railway):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require"

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# OpenRouter (AI)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini

# Crypto market data (CoinGecko — optional demo/pro API key improves rate limits)
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
# COINGECKO_API_KEY=your-coingecko-demo-or-pro-api-key

# CryptoPanic (news — optional; fallback data used if missing or rate-limited)
CRYPTOPANIC_API_KEY=your-cryptopanic-api-key

# CORS
CLIENT_URL=http://localhost:5173

# Public API base URL (used for meme image proxy links returned to the client)
API_PUBLIC_BASE_URL=http://localhost:5000
